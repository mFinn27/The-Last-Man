        t\u1EE5c di chuy\u1EC3n."
    - tenNhanVat: "S\xE1t Th\u1EE7"
      hinhAnhDaiDien: {fileID: 7385053672953337032, guid: ab111f7fd663d4b45a3832e8b6642977, type: 3}
      noiDung: "\u0110\xFAng l\xE0 m\u1ED9t th\u1EB1ng nh\xF3c li\u1EC1u l\u0129nh.
