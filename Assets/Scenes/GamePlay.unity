--- !u!114 &961704359
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 961704357}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1dfac4a7840845b459b1848e52e1e536, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  testMode: 0
  danhSachCotTruyen:
  - idSuKien: Wave1_GapLuHanh
    truocWaveSo: 1
    npcPrefab: {fileID: 9020193919793380619, guid: 5856f8c72ae817e4f9d29e343441ddf8, type: 3}
    kichBan:
    - tenNhanVat: "C\u1EADu Nh\xF3c"
      hinhAnhDaiDien: {fileID: -7048852950998510024, guid: ddad65f9d832ff340ab64bd826b85ab3, type: 3}
      noiDung: "\u01A1...\u0111au \u0111\u1EA7u qu\xE1!! \u0110\xE2y l\xE0 \u0111\xE2u
        v\u1EADy ?"
    - tenNhanVat: "Ng\u01B0\u1EDDi L\u1EEF H\xE0nh"
      hinhAnhDaiDien: {fileID: -1554689200894317539, guid: 8e18a467c9819b44389ea81242b07407, type: 3}
      noiDung: "T\u1EC9nh r\u1ED3i \xE0. C\u1EADu \u0111ang \u1EDF h\u1EA7m ng\u1EE5c
        c\u1EE7a l\xE2u \u0111\xE0i Ma V\u01B0\u01A1ng ! T\xF4i l\xE0 m\u1ED9t ng\u01B0\u1EDDi
        L\u1EEF H\xE0nh s\u1ED1ng \u1EDF \u0111\xE2y, \u0111\u1EBFn gi\u1EDD v\u1EABn
        ch\u01B0a b\u1ECB ch\xFAng ph\xE1t hi\u1EC7n ra."
    - tenNhanVat: "C\u1EADu Nh\xF3c"
      hinhAnhDaiDien: {fileID: -7048852950998510024, guid: ddad65f9d832ff340ab64bd826b85ab3, type: 3}
      noiDung: "L..L\xC2U \u0110\xC0I MA V\u01AF\u01A0NG ?? T\u1EA1i sao t\xF4i l\u1EA1i
        \u1EDF \u0111\xE2y ch\u1EE9"
    - tenNhanVat: "C\u1EADu Nh\xF3c"
      hinhAnhDaiDien: {fileID: -7048852950998510024, guid: ddad65f9d832ff340ab64bd826b85ab3, type: 3}
      noiDung: "T\xF4i nh\u1EDB l\xE0 t\xF4i \u0111ang tr\xEAn \u0111\u01B0\u1EDDng
        giao h\xE0ng sang th\u1ECB tr\u1EA5n k\u1EBF b\xEAn v\u1EDBi gia \u0111\xECnh
        c\u1EE7a t\xF4i m\xE0 ??"
    - tenNhanVat: "Ng\u01B0\u1EDDi L\u1EEF H\xE0nh"
      hinhAnhDaiDien: {fileID: -1554689200894317539, guid: 8e18a467c9819b44389ea81242b07407, type: 3}
      noiDung: "C\u1EADu th\u1EF1c s\u1EF1 kh\xF4ng nh\u1EDB g\xEC sao ? Gia \u0111\xECnh
        c\u1EADu b\u1ECB Ma Qu\xE2n, ch\xFAng l\xE0 nh\u1EEFng t\xEAn thu\u1ED9c
        h\u1EA1 c\u1EE7a Ma V\u01B0\u01A1ng b\u1EAFt v\u1EC1 l\xE0m tay sai."
    - tenNhanVat: "Ng\u01B0\u1EDDi L\u1EEF H\xE0nh"
      hinhAnhDaiDien: {fileID: -1554689200894317539, guid: 8e18a467c9819b44389ea81242b07407, type: 3}
      noiDung: "C\u1EADu \u0111ang n\u1EB1m ngh\u1EC9 trong xe h\xE0ng n\xEAn ch\xFAng
        kh\xF4ng bi\u1EBFt. T\xF4i th\u1EA5y c\xF3 xe h\xE0ng gi\u1EEFa \u0111\u01B0\u1EDDng
        n\xEAn t\xF4i mang v\u1EC1 \u0111\u1EC3 xem c\xF3 g\xEC d\xF9ng \u0111\u01B0\u1EE3c
        kh\xF4ng th\xEC th\u1EA5y c\u1EADu n\u1EB1m trong xe !!"
    - tenNhanVat: "C\u1EADu Nh\xF3c"
      hinhAnhDaiDien: {fileID: -7048852950998510024, guid: ddad65f9d832ff340ab64bd826b85ab3, type: 3}
      noiDung: "T\xF4i ph\u1EA3i \u0111i c\u1EE9u gia \u0111\xECnh c\u1EE7a m\xECnh
        ngay th\xF4i. Thi\u1EBFu h\u1ECD th\xEC t\xF4i c\u0169ng ch\u1EB3ng mu\u1ED1n
        s\u1ED1ng n\u1EEFa"
    - tenNhanVat: "Ng\u01B0\u1EDDi L\u1EEF H\xE0nh"
      hinhAnhDaiDien: {fileID: -1554689200894317539, guid: 8e18a467c9819b44389ea81242b07407, type: 3}
      noiDung: "C\u1EADu nh\xECn l\u1EA1i m\xECnh xem !! V\u0169 kh\xED kh\xF4ng
        c\xF3, c\u1EADu \u0111\u1ECBnh tay kh\xF4ng b\u1EAFt c\u01B0\u1EDBp sao ??
        Ch\xFAng \u0111\u1EC1u l\xE0 nh\u1EEFng con \xE1c qu\u1EF7 th\u1EF1c th\u1EE5,
        kh\xF4ng d\u1EC5 d\xE0ng g\xEC c\u1EADu c\xF3 th\u1EC3 \u0111\xE1nh b\u1EA1i
        m\xE0 kh\xF4ng d\xF9ng v\u0169 kh\xED \u0111\xE2u."
    - tenNhanVat: "C\u1EADu Nh\xF3c"
      hinhAnhDaiDien: {fileID: -7048852950998510024, guid: ddad65f9d832ff340ab64bd826b85ab3, type: 3}
      noiDung: "V\u1EADy t\xF4i ph\u1EA3i l\xE0m sao \u0111\xE2y !!"
    - tenNhanVat: "Ng\u01B0\u1EDDi L\u1EEF H\xE0nh"
      hinhAnhDaiDien: {fileID: -1554689200894317539, guid: 8e18a467c9819b44389ea81242b07407, type: 3}
      noiDung: "Th\xF4i \u0111\u01B0\u1EE3c r\u1ED3i. N\u1EBFu c\u1EADu \u0111\xE3
        quy\u1EBFt t\xE2m \u0111\u1EBFn v\u1EADy, t\xF4i s\u1EBD cho c\u1EADu m\u01B0\u1EE3n
        nh\u1EEFng lo\u1EA1i v\u0169 kh\xED n\xE0y. Ch\xFAng s\u1EBD h\u1EEFu \xEDch
        v\u1EDBi c\u1EADu r\u1EA5t nhi\u1EC1u !!"
    - tenNhanVat: "Ng\u01B0\u1EDDi L\u1EEF H\xE0nh"
      hinhAnhDaiDien: {fileID: -1554689200894317539, guid: 8e18a467c9819b44389ea81242b07407, type: 3}
      noiDung: "L\xE2u \u0111\xE0i n\xE0y c\xF3 20 T\u1EA7ng v\xE0 d\u0129 nhi\xEAn
        t\u1EA7ng n\xE0o c\u0169ng s\u1EBD c\xF3 Ma Qu\xE2n canh g\xE1c. C\u1EADu
        mu\u1ED1n c\u1EE9u gia \u0111\xECnh m\xECnh th\xEC c\u1EA7n \u0111\xE1nh
        b\u1EA1i h\u1EBFt ch\xFAng v\xE0 \u0111\u1EBFn \u0111\u01B0\u1EE3c t\u1EA7ng
        20. Gia \u0111\xECnh c\u1EADu c\xF3 th\u1EC3 s\u1EBD \u1EDF \u0111\xF3, c\u0169ng
        c\xF3 th\u1EC3 s\u1EBD c\xF3 nh\u1EEFng ng\u01B0\u1EDDi kh\xE1c c\u1EA7n
        gi\xFAp \u0111\u1EE1 n\u1EEFa !!"
    - tenNhanVat: "C\u1EADu Nh\xF3c"
      hinhAnhDaiDien: {fileID: -7048852950998510024, guid: ddad65f9d832ff340ab64bd826b85ab3, type: 3}
      noiDung: "\u0110\u01B0\u1EE3c r\u1ED3i !! C\u1EA3m \u01A1n ng\xE0i r\u1EA5t
        nhi\u1EC1u, n\u1EBFu c\xF3 th\u1EC3 t\xF4i c\u0169ng s\u1EBD c\u1EE9u c\u1EA3
        nh\u1EEFng ng\u01B0\u1EDDi c\u1EA7n gi\xFAp \u0111\u1EE1 !!"
    - tenNhanVat: "Ng\u01B0\u1EDDi L\u1EEF H\xE0nh"
      hinhAnhDaiDien: {fileID: -1554689200894317539, guid: 8e18a467c9819b44389ea81242b07407, type: 3}
      noiDung: "L\xEAn \u0111\u01B0\u1EDDng b\xECnh an !!"
    laCutscenePhaDao: 0
    giaDinhPrefab: {fileID: 0}
    kichBanGiaDinh: []
