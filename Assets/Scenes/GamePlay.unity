      noiDung: "T\xEAn Ma V\u01B0\u01A1ng b\u1ECB \u0111\xE1nh b\u1EA1i r\u1ED3i
        \u0111\xFAng kh\xF4ng ?? M\xECnh kh\xF4ng m\u01A1 ch\u1EE9 !!"
    - tenNhanVat: "Ma C\xE0 R\u1ED3ng"
      hinhAnhDaiDien: {fileID: 9151189596863642678, guid: b5b38aef30f65e948aea5d5e337b4962, type: 3}
      noiDung: "Gi\u1ECFi l\u1EAFm c\u1EADu nh\xF3c !! Kh\xF4ng th\u1EC3 tin n\u1ED5i
        ch\u1EC9 m\u1ED9t minh c\u1EADu m\xE0 c\u0169ng t\u1EF1 m\xECnh x\u1EED l\xFD
        \u0111\u01B0\u1EE3c t\xEAn Ma V\u01B0\u01A1ng \u0111\xF3."
    - tenNhanVat: "C\u1EADu Nh\xF3c"
      hinhAnhDaiDien: {fileID: -7048852950998510024, guid: ddad65f9d832ff340ab64bd826b85ab3, type: 3}
      noiDung: "C\xE1i g\xEC !!! V\u1EABn c\xF2n m\u1ED9t t\xEAn s\u1ED1ng s\xF3t
        sao ?? Ta s\u1EBD gi\u1EBFt ng\u01B0\u01A1i !!!"
    - tenNhanVat: "Ma C\xE0 R\u1ED3ng"
      hinhAnhDaiDien: {fileID: 9151189596863642678, guid: b5b38aef30f65e948aea5d5e337b4962, type: 3}
      noiDung: "Khoan \u0111\xE3 !! Ta c\u0169ng l\xE0 d\xE2n th\u01B0\u1EDDng th\xF4i,
        ta th\xE0nh Ma C\xE0 R\u1ED3ng l\xE0 do \u0111\xE3 b\u1ECB m\u1ED9t t\xEAn
        thu\u1ED9c h\u1EA1 c\u1EE7a Ma V\u01B0\u01A1ng c\u1EAFn, ta \u0111\xE3 ph\u1EA3i
        ch\u1ECBu t\u1EE7i nh\u1EE5c m\xE0 s\u1ED1ng trong l\xE2u \u0111\xE0i c\u1EE7a
        h\u1EAFn."
    - tenNhanVat: "Ma C\xE0 R\u1ED3ng"
      hinhAnhDaiDien: {fileID: 9151189596863642678, guid: b5b38aef30f65e948aea5d5e337b4962, type: 3}
      noiDung: "Cu\u1ED1i c\xF9ng \u0111\xE3 c\xF3 ng\u01B0\u1EDDi \u0111\xE1nh b\u1EA1i
        \u0111\u01B0\u1EE3c Ma V\u01B0\u01A1ng \u0111\u1EC3 b\u1EA3n th\xE2n ta \u0111\u01B0\u1EE3c
        gi\u1EA3i tho\xE1t !!!"
    - tenNhanVat: "Ma C\xE0 R\u1ED3ng"
      hinhAnhDaiDien: {fileID: 9151189596863642678, guid: b5b38aef30f65e948aea5d5e337b4962, type: 3}
      noiDung: "C\u1EA3m \u01A1n c\u1EADu r\u1EA5t nhi\u1EC1u c\u1EADu nh\xF3c !!
        Ta ph\u1EA3i v\u1EC1 v\u1EDBi gia \u0111\xECnh c\u1EE7a m\xECnh \u0111\xE2y."
    - tenNhanVat: "Ma C\xE0 R\u1ED3ng"
      hinhAnhDaiDien: {fileID: 9151189596863642678, guid: b5b38aef30f65e948aea5d5e337b4962, type: 3}
      noiDung: "\xC0 \u0111\xFAng r\u1ED3i !! Ta th\u1EA5y c\xF3 m\u1ED9t gia \u0111\xECnh
        c\u0169ng b\u1ECB nh\u1ED1t trong kia, c\u1EADu gi\u1EA3i tho\xE1t cho h\u1ECD
        gi\xFAp ta nh\xE9. T\u1EA1m bi\u1EC7t c\u1EADu ta ph\u1EA3i \u0111i \u0111\xE2y
        !!!"
    - tenNhanVat: "C\u1EADu Nh\xF3c"
      hinhAnhDaiDien: {fileID: -7048852950998510024, guid: ddad65f9d832ff340ab64bd826b85ab3, type: 3}
      noiDung: "\u0110\xFAng r\u1ED3i !!! Gia \u0111\xECnh c\u1EE7a m\xECnh, m\xECnh
        ph\u1EA3i \u0111i t\xECm h\u1ECD th\xF4ii"
    laCutscenePhaDao: 1
    giaDinhPrefab: {fileID: 4127190978844317173, guid: 7079aad6e925362438bd87aabf74ed8f, type: 3}
    kichBanGiaDinh:
    - tenNhanVat: "C\u1EADu Nh\xF3c"
      hinhAnhDaiDien: {fileID: -7048852950998510024, guid: ddad65f9d832ff340ab64bd826b85ab3, type: 3}
      noiDung: "M..M..M\u1ECDi ng\u01B0\u1EDDi !!! M\u1ECDi ng\u01B0\u1EDDi v\u1EABn
        \u1ED5n ch\u1EE9, ch\xFAng c\xF3 l\xE0m g\xEC qu\xE1 \u0111\xE1ng kh\xF4ng
        ?"
    - tenNhanVat: "Gia \u0110\xECnh"
      hinhAnhDaiDien: {fileID: -664501723113990750, guid: a3359062ab8497d4b95da7fb2c59b72a, type: 3}
      noiDung: "Ch\xFAng ta v\u1EABn \u1ED5n, c\u0169ng may l\xE0 con \u0111\u1EBFn
        c\u1EE9u k\u1ECBp th\u1EDDi, ch\u1EC9 ch\u1EADm m\u1ED9t ch\xFAt th\xF4i
        l\xE0 ch\xFAng ta \u0111\xE3 tr\u1EDF th\xE0nh v\u1EADt t\u1EBF cho Ma V\u01B0\u01A1ng
        r\u1ED3i !!"
    - tenNhanVat: "Gia \u0110\xECnh"
      hinhAnhDaiDien: {fileID: -664501723113990750, guid: a3359062ab8497d4b95da7fb2c59b72a, type: 3}
      noiDung: "Ban \u0111\u1EA7u ch\xFAng b\u1EAFt nh\xE0 m\xECnh l\xE0m tay sai
        cho b\u1ECDn ch\xFAng, h\u1EA7u h\u1EA1, c\u01A1m b\u01B0ng n\u01B0\u1EDBc
        r\xF3t cho ch\xFAng m\u1ED7i ng\xE0y, c\u1EF1c kh\u1ED5 l\u1EAFm !!!"
    - tenNhanVat: "Gia \u0110\xECnh"
      hinhAnhDaiDien: {fileID: -664501723113990750, guid: a3359062ab8497d4b95da7fb2c59b72a, type: 3}
      noiDung: "Khi ch\xFAng ch\xE1n r\u1ED3i, ch\xFAng \u0111\u1ECBnh d\xE2ng ch\xFAng
        ta l\xEAn cho Ma V\u01B0\u01A1ng th\xEC con \u0111\xE3 \u0111\u1EBFn k\u1ECBp
        th\u1EDDi \u0111\u1EC3 gi\u1EA3i c\u1EE9u !!"
    - tenNhanVat: "Gia \u0110\xECnh"
      hinhAnhDaiDien: {fileID: -664501723113990750, guid: a3359062ab8497d4b95da7fb2c59b72a, type: 3}
      noiDung: "Con gi\u1ECFi l\u1EAFm !! Con l\xE0 ni\u1EC1m t\u1EF1 h\xE0o c\u1EE7a
        nh\xE0 n\xE0y <3"
    - tenNhanVat: "C\u1EADu Nh\xF3c"
      hinhAnhDaiDien: {fileID: -7048852950998510024, guid: ddad65f9d832ff340ab64bd826b85ab3, type: 3}
      noiDung: "HuHu...Kh\xF4ng ai b\u1ECB g\xEC l\xE0 t\u1ED1t r\u1ED3i !! Con nh\u1EDB
        m\u1ECDi ng\u01B0\u1EDDi l\u1EAFm.."
    - tenNhanVat: "Gia \u0110\xECnh"
      hinhAnhDaiDien: {fileID: -664501723113990750, guid: a3359062ab8497d4b95da7fb2c59b72a, type: 3}
      noiDung: "M\u1ECDi th\u1EE9 \u0111\xE3 \u1ED5n r\u1ED3i !! Ch\xFAng ta c\xF9ng
        v\u1EC1 nh\xE0 n\xE0o <3"
